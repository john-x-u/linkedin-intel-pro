{
  "manifest_version": 3,
  "name": "LinkedIn Profile Analyzer",
  "version": "1.0.0",
  "description": "Analyze LinkedIn profiles to discover how connections can help your project",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "action": {
    "default_title": "LinkedIn Analyzer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "settings/settings.html",
  "background": {
    "service_worker": "background/background.js"
  }
}
